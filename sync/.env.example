OLD_SITE_BASE_URL=https://www.onlinegarden.it

# Opzione A (consigliata): API WooCommerce REST
# Esempio: https://www.onlinegarden.it/wp-json/wc/v3
WOOCOMMERCE_API_BASE=
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Opzione B (fallback): API WordPress posts + scraping/metadati custom (da implementare caso per caso)
WP_API_BASE=

# Shopify Admin API (necessario per import/sync)
SHOPIFY_ADMIN_SHOP=your-store.myshopify.com
SHOPIFY_ADMIN_API_VERSION=2025-07
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Modalità e limiti
SYNC_PAGE_SIZE=50
SYNC_MAX_PAGES=0

# CSV import mode
WOO_CSV_PATH=
WOO_PRODUCTS_CSV_PATH=
SHOPIFY_TEMPLATE_CSV_PATH=
SHOPIFY_OUTPUT_CSV_PATH=sync/out/shopify-products-draft-import.csv
WOO_PRODUCTS_LIMIT=0
ALLOW_ZERO_PRICE=false
ALLOW_MISSING_SKU=true
DEFAULT_VENDOR=Online Garden

# AI enrichment adapter
AI_ENRICH_MODE=mock
AI_ENRICH_ENDPOINT=
AI_ENRICH_API_KEY=
AI_ENRICH_TIMEOUT_MS=30000
AI_ENRICH_CONCURRENCY=2

# Optional reviewed CSV for push script
REVIEWED_SHOPIFY_CSV_PATH=
SHOPIFY_PUSH_DELAY_MS=300
SHOPIFY_PUSH_LIMIT=0
SHOPIFY_PUBLISH_ON_CREATE=false

# Customer CSV conversion mode
WOO_CUSTOMERS_CSV_PATH=
SHOPIFY_CUSTOMERS_CSV_OUTPUT=sync/out/shopify-customers-import.csv
CUSTOMER_SYNC_LIMIT=0
