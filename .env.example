# ---------------------------------------------------------------------------
# PUBLIC frontend variables (Vite `VITE_*`) — shipped in the browser bundle.
# These are safe to expose: the Supabase publishable/anon key and the Shopify
# Storefront API token are public by design. NEVER put admin/service keys here.
# ---------------------------------------------------------------------------

# Supabase (public)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Shopify Storefront API (public)
VITE_SHOPIFY_STORE_PERMANENT_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=
VITE_SHOPIFY_STOREFRONT_API_VERSION=2025-07

# ---------------------------------------------------------------------------
# SERVER-SIDE ONLY — set these as Supabase Edge Function secrets, NEVER here
# and NEVER prefixed with VITE_ (a VITE_ prefix would expose them to the browser):
#   SHOPIFY_STORE_PERMANENT_DOMAIN
#   SHOPIFY_ACCESS_TOKEN          (Shopify Admin API token)
#   SHOPIFY_ADMIN_API_VERSION     (e.g. 2025-07)
#   OPENAI_API_KEY
#   LOVABLE_API_KEY
#   SUPABASE_SERVICE_ROLE_KEY
# ---------------------------------------------------------------------------
